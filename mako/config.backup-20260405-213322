font=Inter 12
background-color=#1e2326
text-color=#D3C6AAFF
border-color=#8D05F5
default-timeout=5000
ignore-timeout=true
group-by=app-name
progress-color=over #0901ffff
border-size=1
border-radius=8
padding=10
outer-margin=4
icons=0
max-icon-size=64
icon-path=/usr/share/icons/papirus


[urgency=low]
background-color=#050505
text-color=#D4D4D8FF
default-timeout=3000

[urgency=normal]
background-color=#000000
text-color=#F5F5F5FF

[urgency=critical]
background-color=#1A0E12
text-color=#FFFFFFFF
default-timeout=0

[mode=do-not-disturb]
invisible=true

[category=brightness]
text-color=#1e2326
progress-color=over #A7C080FF

[category=volume]
text-color=#1e2326
progress-color=over #A7C080FF
default-timeout=1700

[category=media]
icons=1
max-icon-size=64
background-color=#1e2326
text-color=#A7C080FF
default-timeout=2000